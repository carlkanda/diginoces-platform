# Diginoces Platform Environment Template
# Copy this file to .env.local for local development.
# Never commit real secrets.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Supabase / Database
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=

# Storage
STORAGE_PROVIDER=supabase
STORAGE_BUCKET=

# Auth / Security
SESSION_SECRET=
TWO_FACTOR_ENABLED=false

# WhatsApp integration - optional for later phases
WHATSAPP_MODE=manual
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# Google Calendar integration - optional for later phases
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Background jobs - optional for later phases
REDIS_URL=

# File generation
PDF_WORKER_MODE=local
