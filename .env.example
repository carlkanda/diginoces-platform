# Diginoces Platform Environment Template
# Copy this file to .env.local for local development.
# Never commit real secrets.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Supabase / Database
# Use the Supabase publishable key for browser/server SSR client access.
# Do not use a service-role key in the web app.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_placeholder
DATABASE_URL=postgresql://postgres:placeholder@localhost:54322/postgres

# Storage
STORAGE_PROVIDER=supabase
STORAGE_BUCKET=diginoces-files

# Auth / Security
TWO_FACTOR_ENABLED=false

# WhatsApp integration - out of scope for Sprint 1.
WHATSAPP_MODE=manual

# Background jobs and file generation are intentionally deferred.
