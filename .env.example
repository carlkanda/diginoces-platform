# Diginoces Platform Environment Template
# Copy this file to .env.local for local development.
# Never commit real secrets.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Do not set NODE_ENV in .env.local or hosting env files.
# Next.js and npm set the runtime mode for dev/build/start commands.

# Supabase / Database
# Use the Supabase publishable key for browser/server SSR client access.
# Use the server-only legacy service-role JWT for backend actions that perform
# their own authorization, such as private Storage signed URL generation.
# Never prefix server secrets with NEXT_PUBLIC_ and never commit a real value.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_placeholder
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=
DATABASE_URL=postgresql://postgres:placeholder@localhost:54322/postgres

# Storage
STORAGE_PROVIDER=supabase
STORAGE_BUCKET=diginoces-files

# Auth / Security
TWO_FACTOR_ENABLED=false

# WhatsApp integration - out of scope for Sprint 1.
WHATSAPP_MODE=manual

# Background jobs and file generation are intentionally deferred.
