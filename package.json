{
  "name": "diginoces-platform",
  "version": "0.1.0",
  "private": true,
  "description": "Diginoces wedding guest-management platform",
  "scripts": {
    "dev": "npm --workspace apps/web run dev",
    "build": "npm --workspaces --if-present run build",
    "lint": "npm --workspaces --if-present run lint",
    "format": "npm --workspaces --if-present run format",
    "format:check": "npm --workspaces --if-present run format:check",
    "test": "npm --workspaces --if-present run test",
    "typecheck": "npm --workspaces --if-present run typecheck",
    "smoke": "npm --workspace apps/web run test -- --run src/lib/platform/smoke.test.ts",
    "db:lint": "node scripts/supabase-db-lint.mjs",
    "backlog:sync-aliases": "node scripts/sync-backlog-aliases.mjs",
    "env:check-public": "node scripts/check-public-env-vars.mjs",
    "secrets:scan": "node scripts/scan-secrets.mjs"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20.9.0"
  },
  "devDependencies": {
    "supabase": "^2.100.1"
  }
}
